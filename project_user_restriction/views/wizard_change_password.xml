<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_wizard_change_password_form" model="ir.ui.view">
    <field name="name">wizard.change.password.form</field>
    <field name="model">wizard.change.password</field>
    <field name="arch" type="xml">
      <form string="Cambiar contraseña">
        <group>
          <field name="user_id"/>
          <field name="new_password"/>
        </group>
        <footer>
          <button string="Cambiar contraseña" type="object" name="action_change_password" class="btn-primary"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_wizard_change_password" model="ir.actions.act_window">
    <field name="name">Cambiar contraseña</field>
    <field name="res_model">wizard.change.password</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
