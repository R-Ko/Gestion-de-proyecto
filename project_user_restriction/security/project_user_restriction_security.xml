<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Rule: project users only see projects where they are assigned or responsible -->
  <record id="rule_project_only_assigned" model="ir.rule">
    <field name="name">Project: Only assigned users or responsible</field>
    <field name="model_id" ref="project.model_project_project"/>
    <field name="domain_force">['|',('assigned_user_ids','in', user.id),('user_id','=', user.id)]</field>
    <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
  </record>
</odoo>
